# Frontend · DEVELOPMENT environment template
# Configure in the Vercel "Development"/preview environment (or copy to
# `.env.local` when pointing your local UI at the shared dev API).
# Safe to commit (no secrets).

# Optional marker mirroring the backend APP_ENV (exposed to the browser bundle).
NEXT_PUBLIC_APP_ENV=development

# URL of the Go API server for this environment.
NEXT_PUBLIC_API_URL=https://api-dev.afere.app

# Clerk — use the DEV instance keys (set the secret in Vercel, never commit it).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# CLERK_SECRET_KEY — set in the Vercel dashboard (server-side only).
