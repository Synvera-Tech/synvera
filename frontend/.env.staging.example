# Frontend · STAGING environment template
# Configure in the Vercel "Preview" environment bound to the staging branch.
# Safe to commit (no secrets).

NEXT_PUBLIC_APP_ENV=staging

# URL of the Go API server for staging.
NEXT_PUBLIC_API_URL=https://api-staging.afere.app

# Clerk — staging instance keys (set the secret in Vercel, never commit it).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# CLERK_SECRET_KEY — set in the Vercel dashboard (server-side only).
