# Frontend environment — copy to .env.local and fill in your values.
# This file is safe to commit. .env.local is gitignored.

# ── Backend API ───────────────────────────────────────────────────────────────
# URL of the Go API server.
# Local development:
NEXT_PUBLIC_API_URL=http://localhost:8080
# Production (Vercel) — set in the Vercel dashboard under Environment Variables:
# NEXT_PUBLIC_API_URL=https://api.afere.app

# ── Clerk Authentication ──────────────────────────────────────────────────────
# Obtain from https://dashboard.clerk.com → Your App → API Keys.
#
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY  — safe to expose in browser bundles.
# CLERK_SECRET_KEY                   — never expose; Vercel server-side only.
#
# Local development:
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_<your-clerk-publishable-key>
CLERK_SECRET_KEY=sk_test_<your-clerk-secret-key>

# Clerk redirect URLs (Vercel production — set via Vercel dashboard):
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
# NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/
