# Frontend · PRODUCTION environment template
# Configure in the Vercel "Production" environment only.
# Safe to commit (no secrets).

NEXT_PUBLIC_APP_ENV=production

# URL of the Go API server in production.
NEXT_PUBLIC_API_URL=https://api.afere.app

# Clerk — LIVE instance keys (set the secret in Vercel, never commit it).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# CLERK_SECRET_KEY — set in the Vercel dashboard (server-side only).
