# Backend · PRODUCTION environment template
# Configure these values ONLY in the Render production service environment.
# NEVER create a real `backend/.env` with production credentials on a developer
# machine. Safe to commit (no secrets).
#
# PRODUCTION = real database. Audited data only. No experimental imports.
# Only approved migrations and seeds, applied via the controlled scripts.

APP_ENV=production

# Neon "synvera_prod" branch/database (pooled connection string).
DATABASE_URL=postgres://USER:PASSWORD@ep-prod-xxxxxxxx.us-east-2.aws.neon.tech/synvera_prod?sslmode=require

# PORT=8080

CLERK_JWKS_URL=https://your-prod-clerk-frontend-api.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://your-prod-clerk-frontend-api.clerk.accounts.dev
