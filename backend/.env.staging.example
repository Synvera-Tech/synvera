# Backend · STAGING environment template
# Configure these values in the Render staging service — do NOT keep a real
# `.env` with staging secrets on developer machines.
# Safe to commit (no secrets).
#
# STAGING = controlled mirror of production. Used to validate migrations, seeds
# and calculations before production. No free experiments.

APP_ENV=staging

# Neon "synvera_staging" branch/database (pooled connection string).
DATABASE_URL=postgres://USER:PASSWORD@ep-staging-xxxxxxxx.us-east-2.aws.neon.tech/synvera_staging?sslmode=require

# PORT=8080

CLERK_JWKS_URL=https://your-staging-clerk-frontend-api.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://your-staging-clerk-frontend-api.clerk.accounts.dev
