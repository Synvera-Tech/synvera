# Backend · DEVELOPMENT environment template
# Copy to `backend/.env` when integrating features against the shared dev DB.
# Safe to commit (no secrets). Fill the real values from your secret manager.
#
# DEVELOPMENT = remote/persistent integration database. MAY contain experimental
# data. Never reuse staging or production credentials here.

APP_ENV=development

# Neon "synvera_dev" branch/database (pooled connection string).
DATABASE_URL=postgres://USER:PASSWORD@ep-dev-xxxxxxxx.us-east-2.aws.neon.tech/synvera_dev?sslmode=require

# PORT=8080

CLERK_JWKS_URL=https://your-dev-clerk-frontend-api.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://your-dev-clerk-frontend-api.clerk.accounts.dev
