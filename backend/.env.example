# Backend environment — copy to .env and fill in your values.
# This file is safe to commit. .env is gitignored.
#
# For environment-specific templates see:
#   .env.local.example · .env.development.example
#   .env.staging.example · .env.production.example
# and docs/deployment/database-environments.md.

# ── Environment ───────────────────────────────────────────────────────────────
# APP_ENV selects the deployment context: local | development | staging | production.
# It drives startup logging and the script guardrails. Unknown/empty ⇒ local
# (never production). It NEVER influences calculations or the data model.
APP_ENV=local

# ── Neon PostgreSQL ───────────────────────────────────────────────────────────
# Find this in your Neon dashboard → Project → Connection string.
# Select "Pooled connection" for production use.
DATABASE_URL=postgres://user:password@ep-xxxxxxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── Server ────────────────────────────────────────────────────────────────────
# Optional — defaults to 8080.
# PORT=8080

# ── Clerk Authentication ──────────────────────────────────────────────────────
# Required in production to validate physician JWTs.
# Leave blank in local dev when using the embedded file-based repo (no auth needed).
#
# CLERK_JWKS_URL  — from Clerk dashboard → API Keys → Advanced → JWKS URL.
#   Format: https://<clerk-frontend-api>/.well-known/jwks.json
#
# CLERK_ISSUER    — the expected JWT "iss" claim.
#   Format: https://<clerk-frontend-api>
#   When blank, issuer validation is skipped (dev convenience only).
#
# Render (production): set these in Dashboard → Environment Variables.
CLERK_JWKS_URL=https://your-clerk-frontend-api.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://your-clerk-frontend-api.clerk.accounts.dev
