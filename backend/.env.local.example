# Backend · LOCAL environment template
# Copy to `backend/.env` for day-to-day local development.
# Safe to commit (no secrets). The real `.env` is gitignored.
#
# LOCAL = disposable database (Docker/local Postgres) or the embedded file
# catalog. Never point this at staging or production.

APP_ENV=local

# Option A — embedded file catalog (no database needed): leave DATABASE_URL blank.
DATABASE_URL=

# Option B — local Postgres (Docker):
# DATABASE_URL=postgres://synvera:synvera@localhost:5432/synvera_local?sslmode=disable

# Optional — defaults to 8080.
# PORT=8080

# Clerk — leave blank locally when using the embedded file repo (no auth needed).
CLERK_JWKS_URL=
CLERK_ISSUER=
