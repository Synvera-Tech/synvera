.DS_Store

# PDFs (keep in data/raw_pdfs/ only)
/*.pdf

# Go
/backend/bin/
/backend/db/schema.sql
/backend/.env
/backend/main

# Next.js
/frontend/.next/
/frontend/.next-verify/
/frontend/out/
/frontend/node_modules/
/frontend/tsconfig.tsbuildinfo

# Environment — ignore real secret files, but always keep *.example templates.
# Order matters: the negations below must come AFTER the broad `.env.*` rule.
.env
.env.*
!.env.example
!.env.*.example
!*.env.example
/frontend/.env.local
# Vercel CLI pulls real production secrets here — never commit them.
/frontend/.vercel/

# Local artifacts
*.zip
**/__pycache__/
